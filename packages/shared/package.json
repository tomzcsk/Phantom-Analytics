{
  "name": "@phantom/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared TypeScript types for Phantom Analytics",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "type-check": "tsc --noEmit",
    "test": "echo 'No tests for shared types package'"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}

{
  "name": "@phantom/api",
  "version": "1.0.0",
  "private": true,
  "description": "Phantom Analytics — Fastify API (collector + analytics + SSE)",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate --schema src/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema src/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema src/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/static": "6.12.0",
    "@phantom/shared": "*",
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^3.0.3",
    "fastify": "^4.28.0",
    "fastify-sse-v2": "^3.0.0",
    "fastify-type-provider-zod": "^2.0.0",
    "geoip-lite": "^1.4.10",
    "ioredis": "^5.4.0",
    "isbot": "^5.0.0",
    "pino": "^9.0.0",
    "ua-parser-js": "^1.0.38",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "^20.0.0",
    "@types/ua-parser-js": "^0.7.39",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}

{
  "name": "phantom-analytics",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted, privacy-first web analytics platform",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=1.22.0"
  },
  "scripts": {
    "build": "yarn workspaces run build",
    "dev": "concurrently -n api,dashboard -c cyan,magenta \"yarn workspace @phantom/api dev\" \"yarn workspace @phantom/dashboard dev\"",
    "dev:infra": "docker compose -f docker/docker-compose.yml up -d postgres redis",
    "test": "yarn workspaces run test",
    "lint": "eslint packages --ext .ts,.tsx",
    "lint:fix": "eslint packages --ext .ts,.tsx --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/**/*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}

# ============================================================
# Phantom Analytics — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to source control
# ============================================================

# ── Database ───────────────────────────────────────────────
POSTGRES_USER=phantom
POSTGRES_PASSWORD=phantom
POSTGRES_DB=phantom_analytics
DATABASE_URL=postgresql://phantom:phantom@localhost:5432/phantom_analytics

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=          # ตั้งค่าสำหรับ production

# ── API ────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development

# ── Auth ───────────────────────────────────────────────────
# JWT Secret — สร้างด้วย: openssl rand -hex 32
JWT_SECRET=change_me_to_a_32_character_random_string_here

# Admin user (สร้างอัตโนมัติถ้ายังไม่มี user ใน DB)
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme
